# Single source of truth for all configurable build inputs.
# Keep this file compatible with POSIX shell dot-sourcing.

OPENWRT_DOWNLOAD_BASE="https://downloads.openwrt.org/releases"
OPENWRT_RELEASE_SERIES="25.12"

OPENWRT_TARGET="x86"
OPENWRT_SUBTARGET="64"
OPENWRT_PROFILE="generic"

ROOTFS_FILESYSTEM="ext4"
IMAGE_FLAVOR="combined-efi"
ROOTFS_PARTSIZE="500"

ARTIFACT_BASENAME="openwrt-custom-x86-64-efi"

# Packages added on top of the official image manifest and generic profile.
CUSTOM_PACKAGES="openssh-sftp-server luci-i18n-base-zh-cn luci-i18n-firewall-zh-cn luci-i18n-package-manager-zh-cn luci-i18n-attendedsysupgrade-zh-cn"

# Pinned trust anchor for the signed custom APK repository.
CUSTOM_APK_REPOSITORY_URL="https://vonzhen.github.io/openwrt-packages/packages.adb"
CUSTOM_APK_PUBLIC_KEY_SHA256="4e3cc4ee46a6895770efd4893f9efe68e0999ba660f5e3f644a56fd9cef64b5c"
