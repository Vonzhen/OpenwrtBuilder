# Single source of truth for all configurable build inputs.
# Keep this file compatible with POSIX shell dot-sourcing.

OPENWRT_DOWNLOAD_BASE="https://downloads.openwrt.org/releases"
OPENWRT_RELEASE_SERIES="25.12"

OPENWRT_TARGET="x86"
OPENWRT_SUBTARGET="64"
OPENWRT_PROFILE="generic"

ROOTFS_FILESYSTEM="ext4"
IMAGE_FLAVOR="combined-efi"
ROOTFS_PARTSIZE="500"

ARTIFACT_BASENAME="openwrt-custom-x86-64-efi"

# Packages that must be present in every delivered firmware image.
IMAGE_PACKAGES="luci luci-ssl luci-app-package-manager uhttpd uhttpd-mod-ubus"

# Upstream OpenWrt 25.12.5 reference used to guard the Phase 3 LuCI overlay.
# A newer stable release may build only when its official source produces the
# same reviewed script after applying our one permitted change.
PACKAGE_MANAGER_CALL_UPSTREAM_SHA256="3cb9f991ce4ca92ef4c394ae663e513e3154ac9984806118cc061c735c2eb1f5"
